/* coffee_toolkit.rdef – Resource definition for Coffee Toolkit
 *
 * Defines the application icon and metadata.
 */

resource(1, "BEOS:APP_ICON") #'ICON' {
    bitmap data("toolkit.png")
};

resource(1, "BEOS:APPVERSION") appVersion {
    version = 1, 0, 0, 0,
    short = "1.0",
    long = "Coffee Toolkit 1.0"
};

resource(1, "BEOS:APP_SIG") "application/x-vnd.DavidMasson.CoffeeToolkit";
