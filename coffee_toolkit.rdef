/* coffee_toolkit.rdef – Resource definition for Coffee Toolkit */

resource app_version {
    major = 1,
    middle = 0,
    minor = 0,
    variety = 0,
    internal = 0,
    short_info = "1.0",
    long_info = "Coffee Toolkit 1.0"
};

resource(1, "BEOS:APP_SIG") "application/x-vnd.DavidMasson.CoffeeToolkit";
